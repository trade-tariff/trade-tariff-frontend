<h4 class="govuk-heading-s"><%= t 'rules_of_origin.cumulation_methods.heading', cumulation_method: cumulation_method.humanize %></h4>

<div class="cumulation_description">
  <%= t '.description_html' %>
</div>

<div class="govuk-inset-text">
  <p><%= t 'rules_of_origin.cumulation_methods.title', scheme_title: scheme_title, countries: countries, cumulation_method: cumulation_method %></p>
</div>

<div class="cumulation_description">
  <%= govuk_details(summary_text: t('rules_of_origin.cumulation_methods.example_title', cumulation_method: cumulation_method.humanize)) do %>
    <%= t '.description_html' %>
    <p><%= image_tag "cumulation/#{cumulation_method}.png" %></p>
  <% end %>
</div>
