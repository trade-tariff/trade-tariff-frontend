<%= govuk_table(classes: 'govuk-!-margin-bottom-2') do |table| %>
  <% table.with_caption(text: condition_group[:condition], classes: 'govuk-heading-m govuk-!-margin-top-6 govuk-!-margin-bottom-3') %>
  <% table.with_head(rows: [['Document code', 'Requirement', 'Action']]) %>
  <% table.with_body do |body| %>
    <% conditions.each do |condition| %>
      <% body.with_row do |row| %>
        <% if condition.document_code.present? %>
          <% row.with_cell(text: condition.document_code, numeric: true) %>
          <% row.with_cell(text: condition.requirement_text) %>
        <% else %>
          <% row.with_cell(text: '&nbsp;'.html_safe) %>
          <% row.with_cell(text: 'No document provided') %>
        <% end %>
        <% row.with_cell do %>
          <%= condition.action %>
          <br/>
          <%= condition.duty_expression.to_s.html_safe %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
