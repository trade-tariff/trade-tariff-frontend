<%= govuk_table(classes: 'small-table govuk-!-margin-bottom-2') do |table| %>
  <% table.with_caption(text: condition_group[:condition], classes: 'govuk-heading-m govuk-!-margin-top-6 govuk-!-margin-bottom-3') %>
  <% table.with_head(rows: [['Requirement', 'Action', 'Duty expression']]) %>
  <% table.with_body do |body| %>
    <% conditions.each do |condition| %>
      <% body.with_row do |row| %>
        <% row.with_cell { safe_join(['Greater than or equal to ', condition.requirement.to_s.html_safe]) } %>
        <% row.with_cell(text: condition.action) %>
        <% row.with_cell(numeric: true) { condition.duty_expression.to_s.html_safe } %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
