<% content_for :title, goods_nomenclature_title(@section) %>

<% content_for :head do %>
  <meta name="description" content="<%= @section %>">
<% end %>

<%= page_header @section.page_heading %>

<% content_for :bodyClasses, "page--wide" %>

<p>Section <strong><%= @section.numeral %></strong> contains <strong><%= @section.chapters_count %></strong> chapters. Choose the chapter that best matches your goods.</p>

<section class="chapters">
  <%= govuk_table(classes: 'section-browser') do |table| %>
    <% table.with_caption(classes: 'govuk-visually-hidden') do %>
      Chapters for <%= @section %>
    <% end %>
    <% table.with_body do |body| %>
      <% @chapters.each do |chapter| %>
        <% body.with_row do |row| %>
          <% row.with_cell(classes: 'section-id-col') do %>
            <div class="chapter-code">
              <span class="code-text"><%= chapter.short_code %></span>
            </div>
          <% end %>
          <% row.with_cell do %>
            <%= govuk_link_to chapter, chapter_path(chapter, request.query_parameters.symbolize_keys), visually_hidden_prefix: "Chapter #{chapter.short_code}:" %>
            <%= render partial: 'chapters/chapter_guides', locals: { chapter: chapter } %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</section>

<%= render 'shared/notes', section_note: @section.section_note %>
