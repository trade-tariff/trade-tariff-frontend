<%= form_with model: search_form,
              url: chemical_search_path,
              method: :get,
              scope: nil,
              local: true,
              builder: GOVUKDesignSystemFormBuilder::FormBuilder,
              class: "tariff-search quota-search #{@section_css}",
              id: 'new_search' do |f| %>
  <%= page_header t('chemical_search.form.page_header') %>

  <%= f.govuk_text_field :cas,
                         width: 'one-quarter',
                         id: 'cas',
                         name: 'cas',
                         label: { text: t('chemical_search.form.cas_label'), for: 'cas' } %>

  <%= f.govuk_text_field :name,
                         width: 'one-half',
                         id: 'name',
                         name: 'name',
                         label: { text: t('chemical_search.form.name_label'), for: 'name' } %>

  <%= f.govuk_submit t('chemical_search.form.submit'),
                     name: 'new_search',
                     value: t('chemical_search.form.submit') %>
<% end %>
