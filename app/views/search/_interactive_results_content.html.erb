<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <p class="govuk-body-l">
      The results below are based on the details you supplied with the strongest result first.
      You can view search details to see your initial search term and following questions and answers.
      This information might be helpful if you need to contact HMRC for more information.
    </p>

    <details class="govuk-details" data-controller="copy-search-details">
      <summary class="govuk-details__summary">
        <span class="govuk-details__summary-text">View search details</span>
      </summary>
      <div class="govuk-details__text">
        <p class="govuk-body-s"><strong>Search term:</strong> <%= @search.q %></p>
        <% if @results.answered_questions.any? %>
          <% @results.answered_questions.each do |qa| %>
            <p class="govuk-body-s govuk-!-margin-bottom-1">
              <strong><%= qa['question'] %></strong><br>
              <%= qa['answer'] %>
            </p>
          <% end %>
        <% end %>
        <button class="govuk-button govuk-button--secondary govuk-!-margin-top-2"
                data-action="copy-search-details#copy"
                data-copy-search-details-target="button">
          Copy search details
        </button>
      </div>
    </details>

    <div class="govuk-warning-text">
      <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
      <strong class="govuk-warning-text__text">
        <span class="govuk-visually-hidden">Warning</span>
        You are responsible for using the correct commodity codes and complying with customs rules.
      </strong>
    </div>

    <% display_results = @results.result_limit.zero? ? @results.all : @results.all.first(@results.result_limit) %>

    <h2 class="govuk-heading-m">Top search results</h2>

    <div class="interactive-results">
      <% display_results.each do |result| %>
        <div class="interactive-result">
          <div class="interactive-result__content">
            <h3 class="govuk-heading-s govuk-!-margin-bottom-1">
              <%= result.classification_description %>
            </h3>
            <p class="govuk-body-s govuk-!-margin-bottom-2 govuk-!-text-colour-secondary">
              <%= result.self_text %>
            </p>
            <%= link_to "View this commodity code (opens in new tab)",
                commodity_path(result.goods_nomenclature_item_id, request_id: @search.request_id),
                class: "govuk-link",
                target: "_blank",
                rel: "noopener noreferrer" %>
          </div>
          <div class="interactive-result__confidence">
            <%= render_confidence_meter(result.try(:confidence)) %>
          </div>
        </div>
      <% end %>
    </div>

    <details class="govuk-details govuk-!-margin-top-6">
      <summary class="govuk-details__summary">
        <span class="govuk-details__summary-text">How we calculate confidence</span>
      </summary>
      <div class="govuk-details__text">
        <p>Our system analyses your search term and answers to find the most relevant commodity codes.</p>
        <ul class="govuk-list govuk-list--bullet">
          <li><strong>Strong result</strong> - High confidence this is the correct classification</li>
          <li><strong>Good result</strong> - Likely correct but you may want to verify</li>
          <li><strong>Possible result</strong> - Worth considering but less certain</li>
          <li><strong>Unlikely result</strong> - Low confidence, included for completeness</li>
        </ul>
      </div>
    </details>
  </div>

  <div class="govuk-grid-column-one-third">
    <%= render 'search/interactive_results_sidebar' %>
  </div>
</div>
