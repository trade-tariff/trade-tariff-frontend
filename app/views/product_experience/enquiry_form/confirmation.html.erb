<% content_for :title, "#{enquiry_form_title('Confirmation')}" %>
<div class="govuk-width-container">
  <main class="govuk-main-wrapper govuk-main-wrapper--l" id="main-content" role="main">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <div class="govuk-panel govuk-panel--confirmation">
          <h1 class="govuk-panel__title">
            Your request has been submitted
          </h1>
          <div class="govuk-panel__body">
            Your reference number<br><strong><%= @reference_number %></strong>
          </div>
        </div>
        <h2 class="govuk-heading-m">What happens next?</h2>
        <p class="govuk-body">We will email you with a reminder of your enquiry and your reference number.</p>
        <p class="govuk-body">
          We aim to respond to the majority of queries inside 5 working days. However, if your query relates to valuation, origin and in some areas of complex classification, it can take up to 10 working days.
        </p>
        <h2 class="govuk-heading-m">Other ways to find information</h2>
        <p class="govuk-body">While we look into your question, you may also find it helpful to:</p>
        <ul class="govuk-list govuk-list--bullet">
          <li>
            check the <%= govuk_link_to 'Help section',
                                        help_path,
                                        id: 'enquiry-form-confirmation-help-link',
                                        data: {
                                          controller: 'analytics',
                                          action: 'click->analytics#track',
                                          analytics_event: 'confirmation_help_clicked',
                                        } %>
          </li>
          <li>
            look at the <%= govuk_link_to 'Live issues log',
                                          live_issues_path,
                                          id: 'enquiry-form-confirmation-live-issues-link',
                                          data: {
                                            controller: 'analytics',
                                            action: 'click->analytics#track',
                                            analytics_event: 'confirmation_live_issues_clicked',
                                          } %> to see if your issue is already known
          </li>
        </ul>
      </div>
    </div>
  </main>
</div>
