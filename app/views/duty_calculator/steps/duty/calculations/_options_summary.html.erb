<% if @duty_options.size > 1 %>
  <nav>
    <p class="govuk-body govuk-!-margin-bottom-3">See below for the options for paying duties on this import:</p>
    <ul class="app-contents govuk-!-margin-bottom-9">
      <% @duty_options.each.with_index(1) do |option, index| %>
        <li class="govuk-!-margin-bottom-2">
          <%= govuk_link_to(t("duty_calculations.options.heading.#{option.category}.#{option.type}", option_no: index, geographical_area_description: option.geographical_area_description, order_number:  option.order_number), "##{option.type}") %>
        </li>
      <% end %>
    </ul>
  </nav>
<% else %>
  <% if @duty_options.third_country_tariff_option.present? %>
    <%= govuk_warning_text(
      text: @duty_options.third_country_tariff_option.warning_text,
      icon_fallback_text: 'Information',
    ) %>
  <% end %>
<% end %>
