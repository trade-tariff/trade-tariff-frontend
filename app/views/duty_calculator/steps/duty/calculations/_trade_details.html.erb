<%= govuk_details(summary_text: 'Details of your trade') do %>
  <%= govuk_summary_list(actions: false, rows: [
    {
      key: { text: 'Origin:', classes: 'govuk-body-s' },
      value: { text: country_of_origin_description, classes: 'govuk-body-s' },
    },
    {
      key: { text: 'Commodity:', classes: 'govuk-body-s' },
      value: {
        text: "#{commodity.formatted_commodity_code(user_session.additional_codes)}<br>#{commodity.description}".html_safe,
        classes: 'govuk-body-s',
      },
    },
    {
      key: { text: 'Import date:', classes: 'govuk-body-s' },
      value: { text: l(user_session.import_date), classes: 'govuk-body-s' },
    },
    {
      key: { text: 'Valuation of import:', classes: 'govuk-body-s' },
      value: { text: number_to_currency(user_session.total_amount), classes: 'govuk-body-s' },
    },
  ]) %>
<% end %>
