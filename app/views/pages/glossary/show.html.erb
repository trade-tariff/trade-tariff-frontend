<% content_for :back_link do %>
  <%= back_link (request.referer || help_path), javascript: true %>
<% end %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <h1 class="govuk-heading-xl">
      <%= @glossary.term_and_title %>
    </h1>

    <%= render @glossary.key %>
  </div>
</div>
