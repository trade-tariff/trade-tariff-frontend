<section class="app-devolved-nations" aria-label="Applies to">
  <% if TradeTariffFrontend::ServiceChooser.xi? %>
    <h2 class="govuk-heading-s govuk-!-margin-bottom-0">Applies to Northern Ireland</h2>
    <%= govuk_list [govuk_link_to('Guidance for England, Scotland and Wales', '/find_commodity')], classes: 'govuk-!-margin-top-1 govuk-!-margin-bottom-0' %>
  <% else %>
    <h2 class="govuk-heading-s govuk-!-margin-bottom-0">Applies to England, Scotland and Wales</h2>
    <%= govuk_list [govuk_link_to('Guidance for Northern Ireland', '/xi/find_commodity')], classes: 'govuk-!-margin-top-1 govuk-!-margin-bottom-0' %>
  <% end %>
</section>
