<div class="govuk-grid-column-two-thirds">
  <%= govuk_back_link(href: simplified_procedural_values_path) %>
  <%= page_header "Simplified procedure value rates for code #{@result.simplified_procedural_code} - #{@result.goods_nomenclature_label}" %>

  <% if @result.no_data %>
    <p>
      No data found for this SPV code
    </p>
  <% else %>
    <p>
      Applies to commodity code <%= @result.goods_nomenclature_item_ids %>.
    </p>

    <%= govuk_table do |table| %>
      <% table.with_head do |head| %>
        <% head.with_row do |row| %>
          <% row.with_cell(text: 'From') %>
          <% row.with_cell(text: 'To') %>
          <% row.with_cell(text: 'Value per 100 kg', numeric: true) %>
        <% end %>
      <% end %>

      <% table.with_body do |body| %>
        <% @result.measures.each do |measure| %>
          <% body.with_row do |row| %>
            <% row.with_cell(text: measure.validity_start_date&.to_date&.to_formatted_s(:short)) %>
            <% row.with_cell(text: measure.validity_end_date&.to_date&.to_formatted_s(:short)) %>
            <% row.with_cell(text: presented_duty_amount(measure), numeric: true) %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
