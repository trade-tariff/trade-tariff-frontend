<%= page_header do %>
  <h1 class="govuk-heading-xl">
    Live Issues Log
  </h1>
<% end %>

<% content_for :top_breadcrumbs do %>
  <%= generate_breadcrumbs t('breadcrumb.live_issues'), [[t('breadcrumb.news'), '/news']] %>
<% end %>

<%= govuk_table do |table| %>
  <% table.with_head do |head| %>
    <% head.with_row do |row| %>
      <% row.with_cell(text: 'Issue') %>
      <% row.with_cell(text: 'Description', width: 'one-quarter') %>
      <% row.with_cell(text: 'Commodities') %>
      <% row.with_cell { live_issue_status_sort_link(@sort_direction) } %>
      <% row.with_cell(text: 'Dates') %>
      <% row.with_cell(text: 'Suggested action', width: 'one-quarter') %>
    <% end %>
  <% end %>

  <% table.with_body do |body| %>
    <% @live_issues.each do |live_issue| %>
      <% body.with_row do |row| %>
        <% row.with_cell(header: true) do %>
          <%= live_issue.title %>
          <div class="govuk-!-font-size-14 govuk-!-margin-top-5 govuk-!-text-colour-muted">
            Last updated: <br>
            <%= live_issue.updated_at.to_date.to_formatted_s(:long) %>
          </div>
        <% end %>
        <% row.with_cell { markdown_field(live_issue.description) } %>
        <% row.with_cell do %>
          <%= render partial: 'commodities', locals: { live_issue: live_issue } %>
        <% end %>
        <% row.with_cell(text: live_issue.status) %>
        <% row.with_cell(text: live_issue_from_to_date(live_issue)) %>
        <% row.with_cell { markdown_field(live_issue.suggested_action) } %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
