<%= govuk_summary_list(rows: [
  { key: { text: 'Chapter' }, value: { text: @chapter.short_code } },
  { key: { text: 'Classification' }, value: { text: sanitize(@chapter.to_s) } },
  {
    key: { text: 'Date of trade' },
    value: { text: @search.date.to_formatted_s(:long) },
    actions: [{ href: import_export_dates_path(goods_nomenclature_code: current_goods_nomenclature_code) }],
  },
]) %>
