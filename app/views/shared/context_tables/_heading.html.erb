<% rows = [
  { key: { text: 'Heading' }, value: { text: @heading.short_code } },
  { key: { text: 'Classification' }, value: { text: sanitize(@heading.to_s) } },
] %>
<% if @heading.declarable? %>
  <% rows << {
    key: { text: @heading.supplementary_unit_description.to_s },
    value: {
      text: capture do
        concat(tag.p(supplementary_unit_for(uk_declarable, xi_declarable, @search.country)))
        concat(govuk_details(summary_text: 'What are supplementary units?') do
          tag.div('Supplementary units are used when an additional measurement unit is needed on customs declarations. For example: the quantity of the products as well as the weight in kilograms.<br>'.html_safe, class: 'govuk-!-font-size-16')
        end)
      end,
    },
  } %>
<% end %>
<% rows << {
  key: { text: 'Date of trade' },
  value: { text: @search.date.to_formatted_s(:long) },
  actions: [{ href: import_export_dates_path(goods_nomenclature_code: current_goods_nomenclature_code) }],
} %>
<%= govuk_summary_list(rows:) %>
