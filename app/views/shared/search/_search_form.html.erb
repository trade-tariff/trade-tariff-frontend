<%= form_with model: @search,
              url: perform_search_path,
              method: :post,
              scope: nil,
              local: true,
              builder: GOVUKDesignSystemFormBuilder::FormBuilder,
              id: "new_search" do |f| %>

<%= f.govuk_error_summary %>

<% if @search.day_month_and_year_set? %>
  <%= hidden_field_tag :year, @search.year %>
  <%= hidden_field_tag :month, @search.month %>
  <%= hidden_field_tag :day, @search.day %>
<% end %>

<div class="govuk-form-group<%= ' govuk-form-group--error' if @search.errors[:q].any? %>">
  <%= f.govuk_label :q, text: search_label_text %>
  <%= GOVUKDesignSystemFormBuilder::Elements::ErrorMessage.new(f, f.object_name, :q).html %>
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-three-quarters column-three-quarters-mobile-only">
      <%= render 'shared/search/autocomplete' %>
      <%= f.govuk_date_field :as_of,
                              legend: {
                                text: 'When are you planning to trade the goods?',
                                size: 's',
                                tag: 'h1',
                              },
                              hint: {
                                  text: "You can enter the date your goods will be traded. This is important, as commodities, duties and quotas change over time. Use the format day, month, year, for example 27 3 2021. If you don't enter a date, today's date is used.",
                              },
                              form_group: {
                                class: 'govuk-!-margin-top-6',
                            },
                            maxlength_enabled: true if local_assigns.fetch(:use_date_picker, false) %>
    </div>

    <% if @no_shared_search %>
      <div class="govuk-grid-column-three-quarters">
        <%= f.govuk_submit 'Search for a commodity',
                            validate: true,
                            name: 'new_search',
                            value: 'Search for a commodity',
                            class: 'govuk-!-margin-top-6' %>
        <hr>
      </div>
    <% else %>
      <div class="govuk-grid-column-one-quarter column-one-quarter-mobile-only">
        <%= f.govuk_submit 'Search',
                            validate: true,
                            name: 'new_search',
                            value: 'Search',
                            class: 'search-button' %>
      </div>
    <% end %>
  </div>
</div>
<% end %>
