<% unless @feedback %>
<div class="app-feedback-useful-banner govuk-width-container">
  <div class="govuk-!-padding-4">
    <h2 class="govuk-heading-m govuk-!-margin-bottom-1">Give feedback about this service</h2>
    <p class="govuk-body">Tell us about your experience using this service to help us improve it.</p>
    <%= link_to 'Share your feedback', feedback_path, class: 'govuk-button', target: '_blank', rel: 'noopener noreferrer' %>
  </div>
</div>
<% end %>
