<%= govuk_table(classes: 'additional-code-table') do |table| %>
  <% table.with_caption(text: 'Depends on additional code') %>
  <% table.with_head(rows: [['Code', 'Duty']]) %>
  <% table.with_body do |body| %>
    <% measures.each do |m| %>
      <% body.with_row do |row| %>
        <% row.with_cell(text: (m.additional_code&.code.presence || 'No code'), html_attributes: { id: 'additional-code' }) %>
        <% row.with_cell { m.duty_expression.formatted_base.html_safe } %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
