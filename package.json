{
  "name": "trade-tariff-frontend",
  "private": true,
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@babel/preset-env": "^7.29.0",
    "@hotwired/stimulus": "^3.2.2",
    "@playwright/test": "^1.58.2",
    "accessible-autocomplete": "^3.0.1",
    "babel-jest": "^30.3.0",
    "dotenv": "^17.3.1",
    "govuk-frontend": "6.1.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.3.0",
    "jquery": "4.0.0",
    "jquery-grid-navigation": "^1.0.1",
    "jquery-linear-navigation": "^1.0.2",
    "jquery-prevent-scroll-keys": "^1.0.1",
    "js-cookie": "^3.0.5",
    "mark.js": "^8.11.1",
    "sass": "^1.97.3"
  },
  "scripts": {
    "build:css": "sass ./app/assets/stylesheets/application.sass.scss:./app/assets/builds/application.css ./app/assets/stylesheets/print.sass.scss:./app/assets/builds/print.css --no-source-map --load-path=node_modules --load-path=app/assets/stylesheets",
    "axxy": "playwright test"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFiles": [
      "./spec/javascript/setup.js"
    ],
    "testRegex": ".*[_\\.]spec.js",
    "roots": [
      "spec/javascript/controllers",
      "spec/javascript"
    ],
    "testPathIgnorePatterns": [
      "/spec/javascript/accessibility/"
    ],
    "moduleDirectories": [
      "node_modules",
      "app/javascript/src",
      "app/javascript/controllers"
    ],
    "transformIgnorePatterns": [
      "/node_modules/(?!@hotwired/stimulus)",
      "\\.pnp\\.[^\\/]+$"
    ]
  }
}
